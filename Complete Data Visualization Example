# Perform basic data visualization using Seaborn

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Apply Seaborn styling
sns.set_theme()

# Load the dataset
car_data = pd.read_csv("car_data.csv")

# Histogram
sns.histplot(car_data["Price ($)"])
plt.title("Distribution of Car Prices")
plt.show()

# Bar Plot
sns.barplot(
    x="Company",
    y="Price ($)",
    data=car_data
)
plt.title("Average Car Price by Company")
plt.xticks(rotation=45)
plt.show()

# Scatter Plot
sns.scatterplot(
    x="Annual Income",
    y="Price ($)",
    hue="Gender",
    data=car_data
)
plt.title("Annual Income vs Car Price by Gender")
plt.show()
